{
  "name": "boostex",
  "version": "1.0.0",
  "description": "Boostex - AI Chat Bots for Twitch",
  "main": "src/main.ts",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc && npm run build:fe",
    "build:fe": "cd frontend && npm install && npm run build",
    "start": "node dist/main.js",
    "postinstall": "pip install streamlink --break-system-packages || pip3 install streamlink --break-system-packages || true"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "axios": "^1.6.7",
    "colors": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "groq-sdk": "^0.4.0",
    "socket.io": "^4.6.1",
    "tmi.js": "^1.8.5",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@types/tmi.js": "^1.8.6",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.9.5"
  }
}